<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

<!--    Below is a linear layout that holds all your view-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:orientation="vertical">

<!--Below is a text view-->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Health and Wellness app"
            android:textSize="40sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:textColor="@color/black"/>

<!--Below is an image-->

        <!--  Below is button number 1-->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/rounded_image"
            android:scaleType="centerCrop"
            android:src="@drawable/image1" />
        
        <com.google.android.gms.ads.AdView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:id="@+id/adView"
            app:adSize="BANNER"
            app:adUnitId="ca-app-pub-3940256099942544/6300978111"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="15dp">

            <Button
                android:id="@+id/health_recipes"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_margin="8dp"
                android:background="@drawable/button_background"
                app:backgroundTint="@null"
                android:drawableEnd="@drawable/heartbeat"
                android:drawablePadding="10dp"
                android:gravity="center"
                android:padding="12dp"
                android:text="Health Recipes"
                android:textColor="@color/white"
                android:textSize="15sp"/>

            <Button
                android:id="@+id/nutrition_advice"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_margin="8dp"
                android:background="@drawable/button_background"
                app:backgroundTint="@null"
                android:drawableEnd="@drawable/diet"
                android:drawablePadding="10dp"
                android:gravity="center"
                android:padding="12dp"
                android:text="Nutrition Advice"
                android:textColor="@color/white"
                android:textSize="15sp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ROW 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">


            </LinearLayout>

            <!-- ROW 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/start_exercise"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/button_background"
                    app:backgroundTint="@null"
                    android:drawableEnd="@drawable/exercise"
                    android:drawablePadding="10dp"
                    android:gravity="center"
                    android:text="Exercise"
                    android:textSize="15sp"
                    android:textColor="@color/white"/>

                <Button
                    android:id="@+id/meditation"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/button_background"
                    app:backgroundTint="@null"
                    android:drawableEnd="@drawable/meditation"
                    android:drawablePadding="10dp"
                    android:gravity="center"
                    android:text="Meditation"
                    android:textSize="15sp"
                    android:textColor="@color/white"/>
            </LinearLayout>

            <!-- ROW 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/check_progress"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/button_background"
                    app:backgroundTint="@null"
                    android:drawableEnd="@drawable/progress"
                    android:drawablePadding="10dp"
                    android:gravity="center"
                    android:textSize="15sp"
                    android:text="Progress"
                    android:textColor="@color/white"/>

                <Button
                    android:id="@+id/daily_motivation"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/button_background"
                    app:backgroundTint="@null"
                    android:drawableEnd="@drawable/performance"
                    android:drawablePadding="10dp"
                    android:gravity="center"
                    android:text="Motivation"
                    android:textSize="15sp"
                    android:textColor="@color/white"/>
            </LinearLayout>

            <!-- ROW 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/hydration_alert"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/button_background"
                    app:backgroundTint="@null"
                    android:drawableEnd="@drawable/water"
                    android:drawablePadding="10dp"
                    android:gravity="center"
                    android:text="Hydration"
                    android:textSize="15sp"
                    android:textColor="@color/white"/>

                <Button
                    android:id="@+id/weekly_goals"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/button_background"
                    app:backgroundTint="@null"
                    android:drawableEnd="@drawable/target"
                    android:drawablePadding="10dp"
                    android:gravity="center"
                    android:text="Weekly Goals"
                    android:textSize="15sp"
                    android:textColor="@color/white"/>
            </LinearLayout>

        </LinearLayout>


<!--Button no 9-->

        <Button
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:id="@+id/learnmore"
            android:text="Learn more..."
            android:layout_margin="16dp"
            android:background="@drawable/learnmorebackground"
            app:backgroundTint="@null"
            android:drawableRight="@drawable/knowledge"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackground"/>





    </LinearLayout>

</ScrollView>
