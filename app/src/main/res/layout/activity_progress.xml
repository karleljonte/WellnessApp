<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ProgressActivity">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="progress"
            android:textSize="32sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:background="@drawable/shapeb"
            android:padding="10dp"
            android:textColor="@color/white"/>

        <ImageView
            android:id="@+id/nutritionImage"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:src="@drawable/image12"
            android:background="#EEEEEE"/>

        <TextView
            android:id="@+id/progressText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Progress Tracking&#10;&#10;1. Set Your Goals&#10;Define what you want to achieve clearly.&#10;&#10;2. Track Your Workouts&#10;Record the exercises you complete each day.&#10;&#10;3. Monitor Nutrition&#10;Keep track of what you eat and drink.&#10;&#10;4. Stay Consistent&#10;Maintain a regular routine to see results.&#10;&#10;5. Measure Improvements&#10;Check your strength, endurance, or weight changes.&#10;&#10;6. Take Notes&#10;Write down how you feel after workouts or meals.&#10;&#10;7. Use Reminders&#10;Set reminders to stay on track.&#10;&#10;8. Celebrate Milestones&#10;Reward yourself when you reach goals.&#10;&#10;9. Adjust Your Plan&#10;Make changes if something isn’t working.&#10;&#10;10. Stay Motivated&#10;Keep pushing yourself to improve every day."
            android:textSize="16sp"
            android:textColor="@color/black"
            android:padding="16dp"/>

    </LinearLayout>

</ScrollView>