<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".WeeklyGoalsActivity">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Weakly goals"
            android:textSize="32sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:background="@drawable/shapeb"
            android:padding="10dp"
            android:textColor="@color/white"/>
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:paddingTop="10dp"
            android:src="@drawable/image10"
            android:background="@drawable/rounded_image"
            android:scaleType="centerCrop"/>

        <TextView
            android:id="@+id/weeklyGoalsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Weekly Goals&#10;&#10;1. Exercise Regularly&#10;Work out at least 3–5 times this week.&#10;&#10;2. Eat Healthy Meals&#10;Include balanced and nutritious foods daily.&#10;&#10;3. Stay Hydrated&#10;Drink enough water each day.&#10;&#10;4. Get Enough Sleep&#10;Aim for 7–9 hours of sleep every night.&#10;&#10;5. Practice Meditation&#10;Spend 5–10 minutes daily relaxing your mind.&#10;&#10;6. Limit Screen Time&#10;Reduce unnecessary phone and social media usage.&#10;&#10;7. Study or Learn Something New&#10;Dedicate time to learning or improving a skill.&#10;&#10;8. Stay Organized&#10;Plan your tasks and manage your time well.&#10;&#10;9. Stay Positive&#10;Maintain a good mindset and avoid negativity.&#10;&#10;10. Reflect on Progress&#10;Review your achievements at the end of the week."
            android:textSize="16sp"
            android:textColor="@color/black"
            android:padding="16dp"/>

    </LinearLayout>

</ScrollView>