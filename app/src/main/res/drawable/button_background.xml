<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color -->
    <solid android:color="@color/black"/>

    <!-- Rounded corners -->
    <corners android:radius="12dp"/>

    <!-- Border -->
    <stroke
        android:width="2dp"
        android:color="@color/white"/>

    <!-- Padding inside button -->
    <padding
        android:left="12dp"
        android:top="8dp"
        android:right="12dp"
        android:bottom="8dp"/>
</shape>