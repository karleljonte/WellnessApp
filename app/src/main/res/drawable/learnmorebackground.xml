<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background -->
    <solid android:color="@color/black"/>

    <!-- Rounded corners -->
    <corners android:radius="20dp"/>

    <!-- White border -->
    <stroke
        android:width="2dp"
        android:color="@color/white"/>

    <!-- Padding -->
    <padding
        android:left="16dp"
        android:top="12dp"
        android:right="16dp"
        android:bottom="12dp"/>
</shape>